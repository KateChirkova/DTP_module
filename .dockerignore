# Скриншоты для watchdog — это рабочие кадры; в Docker они приходят из тома (…/dtp_data -> /app/data/screenshots),
# а не из образа. Исключаем локальные **/screenshots и data/ только из *контекста сборки*, чтобы не гонять гигабайты в docker build.
data
backend/data
**/screenshots

# Старые прогоны YOLO (не light9) — в рантайме вес только из dtp_krasnodar_light9
backend/src/traffic_dtp/ml/runs/detect/dtp_krasnodar_light/
backend/src/traffic_dtp/ml/runs/detect/dtp_krasnodar_light2/
backend/src/traffic_dtp/ml/runs/detect/dtp_krasnodar_light3/
backend/src/traffic_dtp/ml/runs/detect/dtp_krasnodar_light4/
