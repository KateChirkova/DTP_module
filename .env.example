# Скопируйте в .env в корне репозитория:  copy .env.example .env
# Файл .env не коммитится в git.
# При локальном запуске API из backend/ подхватывается и корневой .env (см. db/session.py).

# Ключ для watchdog -> POST /api/v1/detections (одинаковый в api и watchdog)
DTP_INTERNAL_API_KEY=change-me-to-a-long-random-string
# При make dev / make watch из backend/ продублируйте строку выше в backend/.env

# CORS для фронтенда (Playwright E2E использует localhost:3000)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Первый администратор при пустой БД (создаётся при старте API)
DTP_BOOTSTRAP_LOGIN=admin
DTP_BOOTSTRAP_PASSWORD=admin123
DTP_BOOTSTRAP_ADMIN=1

# YOLO: быстрее (640) vs точнее как при обучении (1280)
# YOLO_IMGSZ=640
# YOLO_CONF=0.25
# Отдельный worker (рекомендуется при частых кадрах): YOLO_WORKER_URL=http://127.0.0.1:18081

# Watchdog (локально без Docker — уже быстрые значения по умолчанию)
# WATCHDOG_STABLE_TIMEOUT=1.5
# WATCHDOG_USE_POLLING=1

# Опционально: секрет для backend/create_test_user.py
# DTP_USER_CREATE_SECRET=
